#!/usr/bin/env bash
# Optional pre-commit: keep plugins/usage-trace skill copy aligned with skills/.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$repo_root" ]]; then
  exit 0
fi

sync_script="$repo_root/scripts/sync-plugin-copies.sh"
src="$repo_root/skills/usage-trace/SKILL.md"
dst="$repo_root/plugins/usage-trace/skills/usage-trace/SKILL.md"

if [[ ! -x "$sync_script" && ! -f "$sync_script" ]]; then
  exit 0
fi

if [[ ! -f "$src" ]]; then
  exit 0
fi

bash "$sync_script" >/dev/null

if [[ -f "$dst" ]]; then
  # Stage thin copy when the authoritative skill is part of this commit
  # or when the thin copy changed.
  if git diff --cached --name-only -- "$src" | grep -q . \
    || git diff --name-only -- "$dst" | grep -q .; then
    git add -- "$dst"
  fi
fi

exit 0
