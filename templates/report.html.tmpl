<!DOCTYPE html>
<html lang="zh" data-theme="light" data-persona="senior">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>usage-trace · {{KEYWORD}}</title>
<style>
  :root{
    /* surfaces */
    --bg:#f6f8fa;--panel:#ffffff;--panel-2:#f1f5f9;--stage:#fbfcfe;
    /* text */
    --ink:#0f172a;--muted:#64748b;--faint:#94a3b8;
    /* lines */
    --line:#e2e8f0;--line-strong:#cbd5e1;
    /* brand */
    --accent:#0f766e;--accent-soft:rgba(15,118,110,.10);--accent-2:#2563eb;--warn:#b45309;
    /* code */
    --code:#eef2f7;
    /* effects */
    --shadow-sm:0 1px 2px rgba(15,23,42,.06);
    --shadow:0 10px 24px rgba(15,23,42,.08);
    --shadow-lg:0 18px 40px rgba(15,23,42,.12);
    /* layer palette */
    --layer-controller:#2563eb;--layer-controller-bg:#e8f0fe;
    --layer-service:#b45309;--layer-service-bg:#fff4d6;
    --layer-repository:#15803d;--layer-repository-bg:#dcfce7;
    --layer-entity:#7c3aed;--layer-entity-bg:#f1e8ff;
    --layer-sql:#be123c;--layer-sql-bg:#ffe4e6;
    --layer-table:#0f766e;--layer-table-bg:#d9f7ef;
    --layer-unknown:#64748b;--layer-unknown-bg:#eef2f6;
    /* type scale */
    --fs-xs:10px;--fs-sm:11px;--fs-base:12px;--fs-md:13px;--fs-lg:15px;--fs-xl:18px;
    /* spacing */
    --sp-1:4px;--sp-2:8px;--sp-3:12px;--sp-4:16px;--sp-5:20px;--sp-6:24px;
    /* radii */
    --r-sm:6px;--r:8px;--r-lg:10px;--r-pill:999px;
    /* misc */
    --toolbar-bg:rgba(255,255,255,.92);
    --group-fill:rgba(255,255,255,.5);
    --node-shadow:0 4px 10px rgba(15,23,42,.08);
    --node-shadow-active:0 10px 18px rgba(15,118,110,.22);
    --edge:#8b99a6;
  }
  [data-theme="dark"]{
    --bg:#0b1120;--panel:#111827;--panel-2:#1f2937;--stage:#0d1424;
    --ink:#e5e7eb;--muted:#94a3b8;--faint:#64748b;
    --line:#1f2a3a;--line-strong:#334155;
    --accent:#2dd4bf;--accent-soft:rgba(45,212,191,.14);--accent-2:#60a5fa;--warn:#fbbf24;
    --code:#0f1a2b;
    --shadow-sm:0 1px 2px rgba(0,0,0,.4);
    --shadow:0 10px 24px rgba(0,0,0,.45);
    --shadow-lg:0 18px 40px rgba(0,0,0,.55);
    --layer-controller:#93c5fd;--layer-controller-bg:rgba(37,99,235,.22);
    --layer-service:#fcd34d;--layer-service-bg:rgba(180,83,9,.22);
    --layer-repository:#86efac;--layer-repository-bg:rgba(21,128,61,.22);
    --layer-entity:#c4b5fd;--layer-entity-bg:rgba(124,58,237,.22);
    --layer-sql:#fda4af;--layer-sql-bg:rgba(190,18,60,.22);
    --layer-table:#5eead4;--layer-table-bg:rgba(15,118,110,.22);
    --layer-unknown:#94a3b8;--layer-unknown-bg:rgba(100,116,139,.22);
    --toolbar-bg:rgba(17,24,39,.92);
    --group-fill:rgba(15,23,42,.4);
    --node-shadow:0 4px 10px rgba(0,0,0,.4);
    --node-shadow-active:0 10px 18px rgba(45,212,191,.28);
    --edge:#64748b;
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    min-height:100vh;
    background:var(--bg);
    color:var(--ink);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,"PingFang SC","Microsoft YaHei",sans-serif;
    font-size:var(--fs-base);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
  }
  button,input{font:inherit;color:inherit}
  .shell{height:100vh;display:grid;grid-template-rows:auto auto 1fr;overflow:hidden}
  header{
    display:flex;align-items:center;justify-content:space-between;gap:var(--sp-4);
    padding:var(--sp-3) var(--sp-5);
    background:var(--panel);border-bottom:1px solid var(--line);
  }
  .title{min-width:0}
  .title h1{margin:0;font-size:var(--fs-xl);line-height:1.2;font-weight:700;letter-spacing:-.01em}
  .title p{margin:4px 0 0;color:var(--muted);font-size:var(--fs-sm);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .stats{display:flex;gap:var(--sp-2);flex-wrap:wrap;justify-content:flex-end}
  .stat{
    min-width:72px;padding:7px 11px;border:1px solid var(--line);border-radius:var(--r);
    background:var(--panel-2);box-shadow:var(--shadow-sm);
  }
  .stat strong{display:block;font-size:var(--fs-lg);line-height:1;color:var(--accent);font-weight:700}
  .stat span{display:block;margin-top:4px;font-size:var(--fs-xs);color:var(--muted);text-transform:uppercase;letter-spacing:.04em}
  /* top bar */
  .topbar{
    display:flex;align-items:center;gap:var(--sp-3);
    padding:var(--sp-2) var(--sp-5);
    background:var(--panel);border-bottom:1px solid var(--line);
  }
  .topbar-legend{flex:1 1 auto;min-width:0;overflow:hidden}
  .legend{display:flex;flex-wrap:wrap;gap:6px;align-items:center}
  .legend-item{
    display:inline-flex;align-items:center;gap:6px;padding:4px 10px;
    border:1px solid var(--line);border-radius:var(--r-pill);background:var(--panel);
    font-size:var(--fs-sm);color:var(--ink);box-shadow:var(--shadow-sm);
  }
  .legend-item .swatch{width:8px;height:8px;border-radius:50%;flex:0 0 auto;background:var(--muted)}
  .legend-item b{margin-left:2px;color:var(--muted);font-weight:600;font-size:var(--fs-xs)}
  .persona-group{display:flex;gap:6px;flex:0 1 auto;flex-wrap:wrap;justify-content:center}
  .persona-group:empty{display:none}
  .theme-toggle{
    flex:0 0 auto;border:1px solid var(--line);background:var(--panel-2);color:var(--ink);
    border-radius:var(--r-pill);padding:5px 14px;cursor:pointer;font-size:var(--fs-sm);
    box-shadow:var(--shadow-sm);transition:border-color .15s,color .15s;
  }
  .theme-toggle:hover{border-color:var(--accent);color:var(--accent)}
  main{display:grid;grid-template-columns:270px minmax(0,1fr) 360px;min-height:0}
  aside,.details{min-height:0;overflow:auto;background:var(--panel);border-right:1px solid var(--line)}
  .details{border-right:0;border-left:1px solid var(--line)}
  .panel-section{padding:var(--sp-3) var(--sp-4);border-bottom:1px solid var(--line)}
  .label{font-size:var(--fs-xs);text-transform:uppercase;color:var(--muted);font-weight:700;letter-spacing:.05em;margin-bottom:9px}
  .search-wrap{display:flex;gap:var(--sp-2)}
  #graph-search{
    width:100%;height:36px;border:1px solid var(--line);border-radius:var(--r);background:var(--panel);
    padding:0 10px;color:var(--ink);outline:none;transition:border-color .15s,box-shadow .15s;
  }
  #graph-search:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
  .layer-tabs{display:flex;flex-direction:column;gap:7px}
  .layer-chip,.layer-tab,.node-jump,.result-item{
    width:100%;border:1px solid var(--line);background:var(--panel);border-radius:var(--r);padding:8px 9px;
    display:flex;align-items:center;gap:var(--sp-2);text-align:left;color:var(--ink);cursor:pointer;
    transition:border-color .15s,background .15s;
  }
  .layer-chip:hover,.layer-tab:hover,.node-jump:hover,.result-item:hover{border-color:currentColor;background:var(--accent-soft)}
  .layer-chip span,.layer-tab:before{width:9px;height:9px;border-radius:50%;background:currentColor;flex:0 0 auto}
  .layer-tab:before{content:""}
  .layer-chip b,.layer-tab b,.node-jump em{margin-left:auto;color:var(--muted);font-style:normal;font-size:var(--fs-base)}
  .layer-tab.active{border-color:var(--accent);background:var(--accent-soft);color:var(--accent);font-weight:700}
  .layer-tab.active b{color:var(--accent)}
  .node-jump span{width:22px;height:22px;border-radius:50%;background:var(--panel-2);display:grid;place-items:center;color:var(--muted);font-size:var(--fs-sm)}
  .node-jump strong{font-size:var(--fs-base);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  #search-results{display:flex;flex-direction:column;gap:7px;margin-top:10px}
  .result-item strong{font-size:var(--fs-base);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .result-item span{font-size:var(--fs-sm);color:var(--muted);margin-left:auto}
  .graph-stage{position:relative;min-width:0;min-height:0;overflow:hidden;background:var(--stage)}
  .toolbar{
    position:absolute;z-index:5;left:14px;top:14px;display:flex;gap:6px;padding:5px;
    background:var(--toolbar-bg);backdrop-filter:saturate(140%) blur(6px);
    border:1px solid var(--line);border-radius:var(--r-lg);box-shadow:var(--shadow);
  }
  .toolbar button{
    min-width:32px;height:30px;border:1px solid var(--line);background:var(--panel);border-radius:var(--r-sm);
    cursor:pointer;color:var(--ink);transition:border-color .15s,color .15s;
  }
  .toolbar button:hover{border-color:var(--accent);color:var(--accent)}
  .toolbar .mode-button{width:auto;padding:0 10px}
  .toolbar .mode-button.active{border-color:var(--accent);background:var(--accent-soft);color:var(--accent);font-weight:700}
  .graph-scroll{width:100%;height:100%;overflow:hidden;cursor:grab}
  .graph-scroll.dragging{cursor:grabbing}
  .trace-graph{width:100%;height:100%;display:block;background:var(--stage)}
  .graph-edge{stroke:var(--edge);stroke-width:1.7;opacity:.74}
  .graph-edge.main-path{stroke:var(--accent);stroke-width:2.4;opacity:1}
  .graph-edge.related{stroke:var(--accent);stroke-width:2.5;opacity:1}
  .graph-edge.dimmed{opacity:.12}
  .graph-node{cursor:pointer;outline:none}
  .graph-node rect{stroke-width:1.6;filter:drop-shadow(var(--node-shadow))}
  .graph-node text{font-size:var(--fs-sm);fill:var(--ink);pointer-events:none}
  .graph-node:hover rect,.graph-node.selected rect,.graph-node.search-hit rect{stroke-width:2.4}
  .graph-node.selected rect{filter:drop-shadow(var(--node-shadow-active))}
  .graph-node.main-path rect{stroke-width:2.1}
  .graph-node.dimmed{opacity:.22}
  .node-controller{color:var(--layer-controller)}.node-controller rect,.node-controller circle{fill:var(--layer-controller-bg);stroke:var(--layer-controller)}
  .node-service{color:var(--layer-service)}.node-service rect,.node-service circle{fill:var(--layer-service-bg);stroke:var(--layer-service)}
  .node-repository{color:var(--layer-repository)}.node-repository rect,.node-repository circle{fill:var(--layer-repository-bg);stroke:var(--layer-repository)}
  .node-entity{color:var(--layer-entity)}.node-entity rect,.node-entity circle{fill:var(--layer-entity-bg);stroke:var(--layer-entity)}
  .node-sql{color:var(--layer-sql)}.node-sql rect,.node-sql circle{fill:var(--layer-sql-bg);stroke:var(--layer-sql)}
  .node-table{color:var(--layer-table)}.node-table rect,.node-table circle{fill:var(--layer-table-bg);stroke:var(--layer-table)}
  .node-unknown{color:var(--layer-unknown)}.node-unknown rect,.node-unknown circle{fill:var(--layer-unknown-bg);stroke:var(--layer-unknown)}
  .node-controller .swatch{background:var(--layer-controller)}
  .node-service .swatch{background:var(--layer-service)}
  .node-repository .swatch{background:var(--layer-repository)}
  .node-entity .swatch{background:var(--layer-entity)}
  .node-sql .swatch{background:var(--layer-sql)}
  .node-table .swatch{background:var(--layer-table)}
  .node-unknown .swatch{background:var(--layer-unknown)}
  .graph-group{pointer-events:none}
  .graph-group .group-frame{fill:var(--group-fill);stroke:currentColor;stroke-width:1.2;stroke-dasharray:7 5;opacity:.42}
  .graph-group .group-label{font-size:var(--fs-base);font-weight:700;fill:currentColor}
  .graph-group.dimmed{opacity:.18}
  .details h2{font-size:var(--fs-lg);margin:0 0 4px;line-height:1.25;font-weight:700}
  .badge-row{display:flex;gap:6px;flex-wrap:wrap;margin:8px 0 12px}
  .badge{display:inline-flex;align-items:center;gap:5px;border:1px solid var(--line);border-radius:var(--r-pill);padding:3px 9px;font-size:var(--fs-sm);color:var(--muted);background:var(--panel)}
  .field{margin:10px 0}
  .field b{display:block;font-size:var(--fs-xs);color:var(--muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px}
  .field code,code{background:var(--code);border-radius:4px;padding:2px 5px;font-size:var(--fs-base)}
  .field pre{margin:0;white-space:pre-wrap;word-break:break-word;background:var(--code);border-radius:var(--r);padding:9px;font-size:var(--fs-base);line-height:1.45;max-height:180px;overflow:auto;color:var(--ink)}
  .link-list{display:flex;flex-direction:column;gap:6px}
  .link-list button{border:1px solid var(--line);background:var(--panel);border-radius:var(--r);padding:7px 8px;text-align:left;cursor:pointer;font-size:var(--fs-base);transition:border-color .15s,background .15s}
  .link-list button:hover{border-color:var(--accent);background:var(--accent-soft)}
  .table-detail-grid{display:grid;grid-template-columns:1fr;gap:var(--sp-2);margin-top:var(--sp-2)}
  .table-detail-grid .field{margin:0}
  .path-list{display:flex;flex-direction:column;gap:var(--sp-2)}
  .path-lane{
    width:100%;border:1px solid var(--line);border-radius:var(--r);background:var(--panel);padding:8px;
    display:grid;grid-template-columns:24px 1fr;gap:var(--sp-2);text-align:left;cursor:pointer;
    transition:border-color .15s,background .15s;
  }
  .path-lane:hover{border-color:var(--accent);background:var(--accent-soft)}
  .path-rank{width:24px;height:24px;border-radius:50%;background:var(--accent-soft);color:var(--accent);display:grid;place-items:center;font-size:var(--fs-base);font-weight:700}
  .path-chain{display:flex;flex-direction:column;gap:5px;min-width:0}
  .path-step{display:block;min-width:0;position:relative;padding-left:12px}
  .path-step:before{content:"";position:absolute;left:3px;top:14px;bottom:-8px;width:1px;background:var(--line)}
  .path-step:last-child:before{display:none}
  .path-step em{display:block;color:var(--muted);font-style:normal;font-size:var(--fs-xs);text-transform:uppercase}
  .path-step strong{display:block;font-size:var(--fs-base);line-height:1.25;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .tour-list{display:flex;flex-direction:column;gap:7px}
  .tour-step{
    width:100%;border:1px solid var(--line);border-radius:var(--r);background:var(--panel);padding:8px;
    display:grid;grid-template-columns:24px 1fr;gap:var(--sp-2);text-align:left;cursor:pointer;
    transition:border-color .15s,background .15s;
  }
  .tour-step:hover{border-color:var(--accent);background:var(--accent-soft)}
  .tour-step span{width:24px;height:24px;border-radius:50%;background:var(--panel-2);display:grid;place-items:center;color:var(--muted);font-size:var(--fs-sm)}
  .tour-step strong{display:block;font-size:var(--fs-base);line-height:1.25}
  .tour-step em{display:block;margin-top:3px;color:var(--muted);font-size:var(--fs-sm);font-style:normal;line-height:1.35}
  .layer-edge{border:1px solid var(--line);border-radius:var(--r);background:var(--panel);padding:8px;margin-top:7px;box-shadow:var(--shadow-sm)}
  .layer-edge strong{display:block;font-size:var(--fs-base);line-height:1.3}
  .layer-edge span{display:block;margin-top:4px;color:var(--muted);font-size:var(--fs-sm)}
  details{margin-top:var(--sp-2)}
  summary{cursor:pointer;color:var(--accent);font-size:var(--fs-base);font-weight:700}
  table{border-collapse:collapse;width:100%;font-size:var(--fs-base);margin-top:7px;table-layout:fixed}
  th,td{border:1px solid var(--line);padding:6px 8px;text-align:left;vertical-align:top;word-break:break-word}
  th{background:var(--panel-2);font-weight:700;color:var(--ink)}
  td code{white-space:pre-wrap;word-break:break-word}
  .muted{color:var(--muted);font-size:var(--fs-base)}
  .notes{font-size:var(--fs-base);color:var(--muted);line-height:1.5}
  #graph-data{display:none}
  /* [data-persona] NodeInfo hooks — populated by T3 */
  [data-persona="pm"] .ni-source,
  [data-persona="pm"] .ni-rel,
  [data-persona="pm"] .ni-complexity{display:none}
  [data-persona="exec"] .ni-source,
  [data-persona="exec"] .ni-complexity{display:none}
  @media (max-width:980px){
    .shell{height:auto;min-height:100vh;overflow:visible}
    header{align-items:flex-start;flex-direction:column}
    .stats{justify-content:flex-start}
    .topbar{flex-wrap:wrap}
    .topbar-legend{flex:1 1 100%}
    main{display:block}
    aside,.details{border:0;border-bottom:1px solid var(--line)}
    .graph-stage{height:62vh;min-height:420px}
  }
</style>
</head>
<body>
<div class="shell">
  <header>
    <div class="title">
      <h1>{{KEYWORD}}</h1>
      <p>{{PROJECT}} · {{LANGUAGE}} · {{GENERATED_AT}}</p>
    </div>
    <div class="stats">
      <div class="stat"><strong>{{USAGES}}</strong><span>usages</span></div>
      <div class="stat"><strong>{{TABLES}}</strong><span>tables</span></div>
      <div class="stat"><strong>{{DEPTH}}</strong><span>depth</span></div>
    </div>
  </header>
  <div class="topbar">
    <div class="topbar-legend">{{LEGEND_HTML}}</div>
    <div id="persona-group" class="persona-group" role="group" aria-label="读者视角"></div>
    <button id="theme-toggle" type="button" class="theme-toggle" title="切换浅色 / 深色主题" aria-label="切换主题">主题</button>
  </div>
  <main>
    <aside>
      <section class="panel-section">
        <div class="label">主路径</div>
        <div class="path-list">{{MAIN_PATHS_HTML}}</div>
      </section>
      <section class="panel-section">
        <div class="label">导览</div>
        <div class="tour-list">{{TOUR_HTML}}</div>
      </section>
      <section class="panel-section">
        <div class="label">搜索节点</div>
        <div class="search-wrap">
          <input id="graph-search" type="search" placeholder="输入方法、类、表名或层级">
        </div>
        <div id="search-results"></div>
      </section>
      <section class="panel-section layer-tabs-section">
        <div class="label">层级</div>
        <div class="layer-tabs" aria-label="Layer filters">{{LAYER_TABS_HTML}}</div>
      </section>
      <section class="panel-section">
        <div class="label">连接最多</div>
        <div class="link-list">{{TOP_NODES_HTML}}</div>
      </section>
      <section class="panel-section">
        <div class="label">层间关系</div>
        {{LAYER_EDGES_HTML}}
      </section>
      <section class="panel-section notes">{{NOTES}}</section>
    </aside>
    <section class="graph-stage">
      <div class="toolbar" aria-label="Graph controls">
        <button type="button" id="view-main" class="mode-button" title="只突出主路径">主路径</button>
        <button type="button" id="view-all" class="mode-button" title="显示全量关系">全量</button>
        <button type="button" id="zoom-in" title="放大">+</button>
        <button type="button" id="zoom-out" title="缩小">-</button>
        <button type="button" id="fit-graph" title="适应窗口">fit</button>
      </div>
      <div id="graph-scroll" class="graph-scroll">
        {{SVG}}
      </div>
    </section>
    <aside class="details">
      <section id="node-details" class="panel-section"></section>
      <section class="panel-section">
        <details>
          <summary>网络全景</summary>
          {{PANORAMA_SVG}}
        </details>
      </section>
      <section class="panel-section">
        <div class="label">涉及表</div>
        {{TABLES_HTML}}
      </section>
      <section class="panel-section">
        <div class="label">XML / SQL 来源</div>
        {{DB_SOURCES_HTML}}
      </section>
      <section class="panel-section">
        <div class="label">使用位置</div>
        {{USAGES_HTML}}
      </section>
    </aside>
  </main>
</div>
<script id="graph-data" type="application/json">{{GRAPH_DATA}}</script>
<script>
(function(){
  const graph = JSON.parse(document.getElementById("graph-data").textContent);
  const nodes = graph.nodes || [];
  const edges = graph.edges || [];
  const mainPaths = graph.main_paths || [];
  const nodeMap = new Map(nodes.map((node) => [node.id, node]));
  const mainNodeIds = new Set(mainPaths.flatMap((path) => path.nodes || []));
  const mainEdgeKeys = new Set();
  for (const path of mainPaths) {
    const ids = path.nodes || [];
    for (let i = 0; i < ids.length - 1; i += 1) mainEdgeKeys.add(edgeKey(ids[i], ids[i + 1]));
  }
  const svg = document.getElementById("trace-graph");
  const scroll = document.getElementById("graph-scroll");
  const details = document.getElementById("node-details");
  const search = document.getElementById("graph-search");
  const results = document.getElementById("search-results");
  const base = {
    x: 0,
    y: 0,
    w: Number(svg.dataset.width || 800),
    h: Number(svg.dataset.height || 600)
  };
  let view = { ...base };
  let selectedId = nodes.length ? nodes[0].id : null;
  let graphMode = mainNodeIds.size ? "main" : "all";
  let activeLayer = "all";
  let dragging = false;
  let dragStart = null;

  function esc(value){
    return String(value == null ? "" : value)
      .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
  }
  function setViewBox(){
    svg.setAttribute("viewBox", `${view.x} ${view.y} ${view.w} ${view.h}`);
  }
  function edgeKey(from, to){
    return `${from}\u001f${to}`;
  }
  function setActiveModeButton(){
    document.getElementById("view-main").classList.toggle("active", graphMode === "main");
    document.getElementById("view-all").classList.toggle("active", graphMode === "all");
  }
  function setActiveLayerTabs(){
    document.querySelectorAll(".layer-tab").forEach((button) => {
      const isActive = (button.dataset.layer || "all") === activeLayer;
      button.classList.toggle("active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  }
  function nodeLayer(id){
    const node = nodeMap.get(id);
    return node && node.layer ? node.layer : "Unknown";
  }
  function edgeTouchesLayer(edge, layer){
    return nodeLayer(edge.from) === layer || nodeLayer(edge.to) === layer;
  }
  function applyLayerTabs(){
    setActiveLayerTabs();
  }
  function applyMainPathView(){
    const useMain = graphMode === "main" && mainNodeIds.size > 0;
    const useLayer = graphMode === "all" && activeLayer !== "all";
    document.querySelectorAll(".graph-node").forEach((el) => {
      const node = nodeMap.get(el.dataset.nodeId);
      const layerMismatch = useLayer && (!node || node.layer !== activeLayer);
      const mainMismatch = useMain && !mainNodeIds.has(el.dataset.nodeId);
      el.classList.toggle("dimmed", layerMismatch || mainMismatch);
    });
    document.querySelectorAll(".graph-group").forEach((el) => {
      const layerMismatch = useLayer && el.dataset.layer !== activeLayer;
      el.classList.toggle("dimmed", layerMismatch);
    });
    document.querySelectorAll(".graph-edge").forEach((el) => {
      const edge = { from: el.dataset.from, to: el.dataset.to };
      const layerMismatch = useLayer && !edgeTouchesLayer(edge, activeLayer);
      const mainMismatch = useMain && !mainEdgeKeys.has(edgeKey(edge.from, edge.to));
      el.classList.toggle("dimmed", layerMismatch || mainMismatch);
      el.classList.remove("related");
    });
    setActiveModeButton();
    applyLayerTabs();
  }
  function applyFocus(id){
    graphMode = "all";
    activeLayer = "all";
    const related = relatedEdges(id);
    const visibleNodes = new Set([id]);
    const visibleEdges = new Set();
    for (const edge of related) {
      visibleNodes.add(edge.from);
      visibleNodes.add(edge.to);
      visibleEdges.add(edgeKey(edge.from, edge.to));
    }
    document.querySelectorAll(".graph-node").forEach((el) => {
      el.classList.toggle("dimmed", !visibleNodes.has(el.dataset.nodeId));
    });
    document.querySelectorAll(".graph-edge").forEach((el) => {
      const isRelated = visibleEdges.has(edgeKey(el.dataset.from, el.dataset.to));
      el.classList.toggle("related", isRelated);
      el.classList.toggle("dimmed", !isRelated);
    });
    document.querySelectorAll(".graph-group").forEach((el) => {
      el.classList.remove("dimmed");
    });
    setActiveModeButton();
    applyLayerTabs();
  }
  function selectLayerTab(layer){
    activeLayer = layer || "all";
    graphMode = "all";
    document.querySelectorAll(".graph-node").forEach((el) => {
      el.classList.remove("selected");
    });
    document.querySelectorAll(".graph-edge").forEach((el) => {
      el.classList.remove("related");
    });
    applyMainPathView();
  }
  function zoom(factor){
    const cx = view.x + view.w / 2;
    const cy = view.y + view.h / 2;
    const nextW = Math.max(220, Math.min(base.w * 1.8, view.w * factor));
    const nextH = Math.max(160, Math.min(base.h * 1.8, view.h * factor));
    view = { x: cx - nextW / 2, y: cy - nextH / 2, w: nextW, h: nextH };
    setViewBox();
  }
  function fitGraph(){
    view = { ...base };
    setViewBox();
  }
  function focusNode(id){
    const node = nodeMap.get(id);
    if (!node) return;
    const targetW = Math.max(420, base.w * 0.42);
    const targetH = Math.max(280, base.h * 0.42);
    view = {
      x: node.x + node.width / 2 - targetW / 2,
      y: node.y + node.height / 2 - targetH / 2,
      w: targetW,
      h: targetH
    };
    setViewBox();
  }
  function relatedEdges(id){
    return edges.filter((edge) => edge.from === id || edge.to === id);
  }
  function connectedNodes(id){
    const found = [];
    for (const edge of relatedEdges(id)) {
      const other = edge.from === id ? edge.to : edge.from;
      const node = nodeMap.get(other);
      if (node) found.push({ node, edge });
    }
    return found;
  }
  function listItems(values){
    const items = (Array.isArray(values) ? values : String(values || "").split(","))
      .map((value) => String(value || "").trim())
      .filter(Boolean);
    return items.length ? items.map((value) => `<code>${esc(value)}</code>`).join("<br>") : '<span class="muted">无</span>';
  }
  function renderTableDetails(node){
    if (node.kind !== "table") return "";
    const ops = node.ops && node.ops.length ? node.ops : String(node.op || "").split(",");
    const statements = node.statement_ids || [];
    const sources = node.source_files || [];
    const sql = node.sql_snippet ? `<pre>${esc(node.sql_snippet)}</pre>` : '<span class="muted">无 SQL 片段</span>';
    return `
      <div class="field"><b>表详情</b>
        <div class="table-detail-grid">
          <div class="field"><b>访问操作</b>${listItems(ops)}</div>
          <div class="field"><b>Statement</b>${listItems(statements)}</div>
          <div class="field"><b>来源文件</b>${listItems(sources)}</div>
          <div class="field"><b>SQL 片段</b>${sql}</div>
        </div>
      </div>
    `;
  }
  function renderDetails(id){
    const node = nodeMap.get(id);
    if (!node) {
      details.innerHTML = '<p class="muted">选择一个节点查看详情。</p>';
      return;
    }
    const badges = [
      node.kind ? `<span class="badge">${esc(node.kind)}</span>` : "",
      node.layer ? `<span class="badge">${esc(node.layer)}</span>` : "",
      node.table ? `<span class="badge">table ${esc(node.table)}</span>` : "",
      node.op ? `<span class="badge">${esc(node.op)}</span>` : ""
    ].join("");
    const usages = (node.usages || []).map((usage) =>
      `<div class="field"><b>${esc(usage.file || "")}:${esc(usage.line || "")}</b><pre>${esc(usage.snippet || "")}</pre></div>`
    ).join("");
    const sql = node.sql_snippet ? `<div class="field"><b>SQL</b><pre>${esc(node.sql_snippet)}</pre></div>` : "";
    const source = node.source_unit ? `<div class="field"><b>Source unit</b><code>${esc(node.source_unit)}</code></div>` : "";
    const sourceFiles = (node.source_files || []).map((file) =>
      `<code>${esc(file)}</code>`
    ).join("<br>");
    const sourceFileBlock = sourceFiles ? `<div class="field"><b>Source files</b>${sourceFiles}</div>` : "";
    const tableDetails = renderTableDetails(node);
    const links = connectedNodes(id).map(({ node: linked, edge }) =>
      `<button type="button" data-node-id="${esc(linked.id)}">${esc(edge.from === id ? "to" : "from")} · ${esc(linked.label || linked.id)}</button>`
    ).join("");
    details.innerHTML = `
      <h2>${esc(node.label || node.id)}</h2>
      <div class="badge-row">${badges}</div>
      ${source}
      ${sourceFileBlock}
      ${tableDetails}
      ${sql}
      <div class="field"><b>Connected nodes</b><div class="link-list">${links || '<span class="muted">无连接节点</span>'}</div></div>
      <div class="field"><b>Usages</b>${usages || '<span class="muted">无使用位置</span>'}</div>
    `;
    details.querySelectorAll("[data-node-id]").forEach((button) => {
      button.addEventListener("click", () => selectNode(button.dataset.nodeId, true));
    });
  }
  function selectNode(id, focus){
    selectedId = id;
    document.querySelectorAll(".graph-node").forEach((el) => {
      el.classList.toggle("selected", el.dataset.nodeId === id);
    });
    document.querySelectorAll(".graph-edge").forEach((el) => {
      el.classList.toggle("related", el.dataset.from === id || el.dataset.to === id);
    });
    renderDetails(id);
    applyFocus(id);
    if (focus) focusNode(id);
  }
  function runSearch(){
    const q = search.value.trim().toLowerCase();
    const matches = q
      ? nodes.filter((node) => [node.label, node.id, node.layer, node.kind, node.table]
          .filter(Boolean).some((value) => String(value).toLowerCase().includes(q)))
      : [];
    const hitIds = new Set(matches.map((node) => node.id));
    document.querySelectorAll(".graph-node").forEach((el) => {
      el.classList.toggle("search-hit", hitIds.has(el.dataset.nodeId));
    });
    results.innerHTML = matches.slice(0, 8).map((node) =>
      `<button type="button" class="result-item" data-node-id="${esc(node.id)}"><strong>${esc(node.label || node.id)}</strong><span>${esc(node.layer || "")}</span></button>`
    ).join("");
    results.querySelectorAll("[data-node-id]").forEach((button) => {
      button.addEventListener("click", () => selectNode(button.dataset.nodeId, true));
    });
  }

  document.querySelectorAll(".graph-node").forEach((el) => {
    el.addEventListener("click", () => selectNode(el.dataset.nodeId, false));
    el.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") selectNode(el.dataset.nodeId, true);
    });
  });
  document.querySelectorAll(".node-jump").forEach((button) => {
    button.addEventListener("click", () => selectNode(button.dataset.nodeId, true));
  });
  document.querySelectorAll(".path-lane").forEach((button) => {
    button.addEventListener("click", () => selectNode(button.dataset.nodeId, true));
  });
  document.querySelectorAll(".tour-step").forEach((button) => {
    button.addEventListener("click", () => selectNode(button.dataset.nodeId, true));
  });
  document.querySelectorAll(".layer-chip").forEach((button) => {
    button.addEventListener("click", () => {
      const layer = button.dataset.layer;
      search.value = layer || "";
      runSearch();
      selectLayerTab(layer || "all");
    });
  });
  document.querySelectorAll(".layer-tab").forEach((button) => {
    button.addEventListener("click", () => selectLayerTab(button.dataset.layer || "all"));
  });
  search.addEventListener("input", runSearch);
  document.getElementById("view-main").addEventListener("click", () => {
    graphMode = "main";
    activeLayer = "all";
    applyMainPathView();
  });
  document.getElementById("view-all").addEventListener("click", () => {
    graphMode = "all";
    activeLayer = "all";
    applyMainPathView();
  });
  document.getElementById("zoom-in").addEventListener("click", () => zoom(0.8));
  document.getElementById("zoom-out").addEventListener("click", () => zoom(1.25));
  document.getElementById("fit-graph").addEventListener("click", fitGraph);
  window.fitGraph = fitGraph;

  svg.addEventListener("wheel", (event) => {
    event.preventDefault();
    zoom(event.deltaY < 0 ? 0.9 : 1.1);
  }, { passive:false });
  svg.addEventListener("pointerdown", (event) => {
    if (event.target.closest(".graph-node")) return;
    dragging = true;
    scroll.classList.add("dragging");
    dragStart = { x:event.clientX, y:event.clientY, view:{ ...view } };
    svg.setPointerCapture(event.pointerId);
  });
  svg.addEventListener("pointermove", (event) => {
    if (!dragging || !dragStart) return;
    const scaleX = view.w / Math.max(svg.clientWidth, 1);
    const scaleY = view.h / Math.max(svg.clientHeight, 1);
    view.x = dragStart.view.x - (event.clientX - dragStart.x) * scaleX;
    view.y = dragStart.view.y - (event.clientY - dragStart.y) * scaleY;
    setViewBox();
  });
  svg.addEventListener("pointerup", () => {
    dragging = false;
    scroll.classList.remove("dragging");
  });
  svg.addEventListener("pointercancel", () => {
    dragging = false;
    scroll.classList.remove("dragging");
  });

  setViewBox();
  applyMainPathView();
  if (selectedId) {
    document.querySelectorAll(".graph-node").forEach((el) => {
      el.classList.toggle("selected", el.dataset.nodeId === selectedId);
    });
    renderDetails(selectedId);
  }
})();
</script>
</body>
</html>
